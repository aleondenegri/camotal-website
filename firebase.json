{
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/**/*.@(js|css|jpg|jpeg|gif|png|svg|ico)",
        "destination": "/:path"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
